<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>正在跳转...</title>
    <meta http-equiv="refresh" content="0; url=/custom-home/">
    <style>
        body {
            background: #0a0a0a;
            color: white;
            font-family: sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }
        .loader {
            border: 4px solid rgba(255,255,255,0.1);
            border-top: 4px solid #fff;
            border-radius: 50%;
            width: 30px;
            height: 30px;
            animation: spin 1s linear infinite;
            margin-right: 10px;
        }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        .message { display: flex; align-items: center; }
    </style>
</head>
<body>
    <div class="message">
        <div class="loader"></div>
        <span>正在加载精彩首页，请稍候...</span>
    </div>
    <!-- 如果浏览器不支持自动跳转，显示手动链接 -->
    <noscript>
        <a href="/custom-home/">点击进入首页</a>
    </noscript>
</body>
</html>